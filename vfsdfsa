local characters = workspace:WaitForChild("Characters")
local proxyHrp = workspace:WaitForChild("Proxy"):WaitForChild("HumanoidRootPart")

local function opt(name, fallback)
    return Options[name] and Options[name].Value or fallback
end

local function getMoveDirection()
    local hum = client.Character and client.Character:FindFirstChildWhichIsA("Humanoid")
    if hum and hum.MoveDirection.Magnitude > 0.01 then
        return hum.MoveDirection, hum.WalkSpeed
    end

    hum = workspace.Proxy:FindFirstChildWhichIsA("Humanoid")
    if hum and hum.MoveDirection.Magnitude > 0.01 then
        return hum.MoveDirection, hum.WalkSpeed
    end

    local x, z = 0, 0
    if userInputService:IsKeyDown(Enum.KeyCode.W) or userInputService:IsKeyDown(Enum.KeyCode.Up) then z -= 1 end
    if userInputService:IsKeyDown(Enum.KeyCode.S) or userInputService:IsKeyDown(Enum.KeyCode.Down) then z += 1 end
    if userInputService:IsKeyDown(Enum.KeyCode.A) or userInputService:IsKeyDown(Enum.KeyCode.Left) then x -= 1 end
    if userInputService:IsKeyDown(Enum.KeyCode.D) or userInputService:IsKeyDown(Enum.KeyCode.Right) then x += 1 end
    if x == 0 and z == 0 then return Vector3.zero, 16 end

    local cam = workspace.CurrentCamera
    if not cam then return Vector3.zero, 16 end
    local look = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z).Unit
    local right = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z).Unit
    return (look * -z + right * x).Unit, 16
end

local function disconnect(list)
    for i = 1, #list do
        if list[i] then list[i]:Disconnect() end
        list[i] = nil
    end
end

-- Shooting
local TestingSection = Tabs.Shooting:AddSection("(testing)")
TestingSection:AddToggle("AntiContest", {Title = "Anti Contest", Default = false})
